# 生产环境配置
PORT=8080
NODE_ENV=production

# MongoDB配置（使用本地或云数据库）
MONGODB_URI=mongodb://localhost:27017/ai_companion

# JWT配置（生产环境必须使用强密钥）
JWT_SECRET=your_very_strong_secret_key_here_at_least_32_chars
JWT_EXPIRES_IN=7d

# 微信小程序配置（必填）
WECHAT_APPID=wx_your_appid_here
WECHAT_SECRET=your_wechat_secret_here

# 微信支付配置（必填）
WECHAT_MCH_ID=your_mch_id
WECHAT_API_KEY=your_api_key
WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/notify

# AI大模型配置（选择其一）
# OpenAI
AI_API_KEY=sk-your_openai_key
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-3.5-turbo

# 或文心一言
# WENXIN_API_KEY=your_key
# WENXIN_SECRET=your_secret

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 短信服务配置（阿里云短信）
SMS_ACCESS_KEY=your_access_key
SMS_SECRET_KEY=your_secret_key
SMS_SIGN_NAME=你的签名
SMS_TEMPLATE_CODE=SMS_xxxxxx

# 日志配置
LOG_LEVEL=info
LOG_PATH=./logs
