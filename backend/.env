# 服务器配置
PORT=8080
NODE_ENV=development

# 数据库配置（使用内存数据库或本地MongoDB）
MONGODB_URI=mongodb://localhost:27017/ai_companion

# JWT配置
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# 微信小程序配置（测试时可不填）
WECHAT_APPID=
WECHAT_SECRET=

# 微信支付配置（测试时可不填）
WECHAT_MCH_ID=
WECHAT_API_KEY=

# AI大模型配置（测试时可不填）
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 短信服务配置（测试时可不填）
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=